# Normalize all text files to LF in repo
* text=auto

# Force LF for code & config (recommended)
*.cs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf

# Binary files
*.zip binary

# Windows-specific scripts (if any)
*.bat text eol=crlf
*.ps1 text eol=crlf
